# Anthropic API (required)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# GitHub API (required — unauthenticated requests are limited to 60/hour)
GITHUB_TOKEN=ghp_your-token-here

# Hugging Face API (optional — increases rate limits)
HF_API_TOKEN=hf_your-token-here

# Email notifications via Resend (optional)
RESEND_API_KEY=re_your-key-here
USER_EMAIL=your-email@example.com

# Streamlit
STREAMLIT_CLIENT_TOOLBARMODE=minimal
