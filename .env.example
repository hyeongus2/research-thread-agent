# Anthropic API key (required for Quick Search and Learning Path AI features)
# Get yours at: https://console.anthropic.com
# Note: This is separate from a Claude.ai Pro subscription.
#       API usage is billed per token at console.anthropic.com regardless of subscription status.
#       Phase 1 (data collection only) works without this key.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# GitHub personal access token (required — unauthenticated requests are limited to 60/hour)
# Create one at: https://github.com/settings/tokens (no special scopes needed for public repos)
GITHUB_TOKEN=ghp_your-token-here

# Hugging Face API token (optional — increases rate limits)
# Get yours at: https://huggingface.co/settings/tokens
HF_API_TOKEN=hf_your-token-here

# Email notifications via Resend (optional — only needed for Phase 4 email digest feature)
# Free tier: 3,000 emails/month. Get key at: https://resend.com
RESEND_API_KEY=re_your-key-here
USER_EMAIL=your-email@example.com

# Streamlit UI config (leave as-is)
STREAMLIT_CLIENT_TOOLBARMODE=minimal
