# Anthropic API key (optional — enables AI Overview, AI Summary, and era analysis)
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=

# GitHub personal access token (required — unauthenticated requests limited to 60/hour)
# Create one at: https://github.com/settings/tokens (no special scopes needed for public repos)
GITHUB_TOKEN=

# Hugging Face API token (optional — increases rate limits for model search)
# Get yours at: https://huggingface.co/settings/tokens
HF_API_TOKEN=

# Semantic Scholar API key (optional — raises rate limit from 100 req/5 min to 1 req/sec)
# Request one at: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# Email notifications via Resend (optional — only needed for email digest feature)
# Free tier: 3,000 emails/month. Get key at: https://resend.com
RESEND_API_KEY=
USER_EMAIL=

# Claude model to use for AI summaries and era analysis (optional — defaults to claude-sonnet-4-6)
# Options: claude-haiku-4-5-20251001  (fast, cheap)
#          claude-sonnet-4-6           (balanced — default)
#          claude-opus-4-7             (most capable, most expensive)
CLAUDE_MODEL=claude-sonnet-4-6
